#!/usr/bin/env sh

set -eu

# Définir ces variables dans le shell avant d'exécuter ce script.
# Le token doit être un GitHub PAT classique avec le scope read:packages.
: "${GHCR_USERNAME:?Variable GHCR_USERNAME manquante}"
: "${GHCR_TOKEN:?Variable GHCR_TOKEN manquante}"
: "${GHCR_EMAIL:?Variable GHCR_EMAIL manquante}"

kubectl create secret docker-registry ghcr-login-secret \
  --docker-server=ghcr.io \
  --docker-username="$GHCR_USERNAME" \
  --docker-password="$GHCR_TOKEN" \
  --docker-email="$GHCR_EMAIL" \
  --dry-run=client \
  --output=yaml \
  | sudo kubectl apply --filename=-
